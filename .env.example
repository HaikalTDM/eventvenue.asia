# Database (Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres

# Public site origin (used in email links, OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Auth
JWT_SECRET=your-secret-key-at-least-32-chars
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=your-refresh-secret-key
REFRESH_TOKEN_EXPIRES_IN=604800

# Email verification gate (false = sign in immediately, no verify required)
EMAIL_VERIFICATION_REQUIRED=false

# Google OAuth (leave empty in dev unless testing the flow)
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# R2 Storage (Cloudflare)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=eventvenue-assets
R2_PUBLIC_URL=https://cdn.eventvenue.asia

# Redis (Upstash)
UPSTASH_REDIS_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Pusher
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1

# Resend Email (empty = falls back to console logging)
RESEND_API_KEY=
RESEND_FROM=EventVenue.Asia <noreply@eventvenue.asia>

# Monitoring
SENTRY_DSN=
AXIOM_TOKEN=
