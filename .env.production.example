# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy to .env.production.local and fill in REAL production values.
# NEVER commit .env.production.local to git.
# All values must point to the production Supabase project, not staging/dev.
# =============================================================================

NODE_ENV=production

# ----- Public site origin -----
NEXT_PUBLIC_APP_URL=https://eventvenue.asia

# ----- Supabase (production project) -----
NEXT_PUBLIC_SUPABASE_URL=https://[PROD-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ----- Postgres (production, separate from dev) -----
# Pooled connection for runtime, direct connection for migrations.
DATABASE_URL=postgresql://postgres.[PROD-PROJECT-REF]:[PROD-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[PROD-PROJECT-REF]:[PROD-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ----- OpenAI -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ----- Monitoring -----
SENTRY_DSN=
AXIOM_TOKEN=
