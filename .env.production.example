# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local and fill in real values.
# NEVER commit .env.production.local to git.
# All values below MUST point to production infrastructure (not staging/dev).
# =============================================================================

NODE_ENV=production

# ----- Database (Supabase, production project) -----
DATABASE_URL=postgresql://postgres:[PROD-PASSWORD]@db.[PROD-PROJECT-REF].supabase.co:6543/postgres

# ----- JWT Auth (rotate these, do NOT reuse dev secrets) -----
JWT_SECRET=replace-with-strong-random-32+chars
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=replace-with-different-strong-random-32+chars
REFRESH_TOKEN_EXPIRES_IN=604800

# ----- R2 Storage (Cloudflare, production bucket) -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=eventvenue-assets
R2_PUBLIC_URL=https://cdn.eventvenue.asia

# ----- Redis (Upstash, production instance) -----
UPSTASH_REDIS_URL=

# ----- OpenAI -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ----- Pusher (production app) -----
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1

# ----- Resend Email (production sender) -----
RESEND_API_KEY=
RESEND_FROM=noreply@eventvenue.asia

# ----- Monitoring -----
SENTRY_DSN=
AXIOM_TOKEN=
