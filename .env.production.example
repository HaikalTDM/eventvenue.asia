# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local and fill in real values.
# NEVER commit .env.production.local to git.
# All values below MUST point to production infrastructure (not staging/dev).
# =============================================================================

NODE_ENV=production

# ----- Public site origin (used in email links, OAuth callbacks) -----
NEXT_PUBLIC_APP_URL=https://eventvenue.asia

# ----- Database (Supabase, production project) -----
DATABASE_URL=postgresql://postgres:[PROD-PASSWORD]@db.[PROD-PROJECT-REF].supabase.co:6543/postgres

# ----- JWT Auth (rotate these, do NOT reuse dev secrets) -----
JWT_SECRET=replace-with-strong-random-32+chars
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=replace-with-different-strong-random-32+chars
REFRESH_TOKEN_EXPIRES_IN=604800

# ----- Email verification gate -----
# When true, new credentials accounts must click the email link before they
# can sign in. Leave false until Resend is configured and a domain is verified.
EMAIL_VERIFICATION_REQUIRED=false

# ----- Google OAuth (leave empty until Google Cloud OAuth client is created) -----
# When NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false the button shows but clicking it
# displays "not yet available". Flip to true after configuring the client.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- R2 Storage (Cloudflare, production bucket) -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=eventvenue-assets
R2_PUBLIC_URL=https://cdn.eventvenue.asia

# ----- Redis (Upstash, production instance) -----
UPSTASH_REDIS_URL=

# ----- OpenAI -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ----- Pusher (production app) -----
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1

# ----- Resend Email (production sender) -----
# When RESEND_API_KEY is empty, all transactional emails fall back to console
# logging (server stdout) so flows can still be tested.
RESEND_API_KEY=
RESEND_FROM=EventVenue.Asia <noreply@eventvenue.asia>

# ----- Monitoring -----
SENTRY_DSN=
AXIOM_TOKEN=
